# ──────────────────────────────────────
# FitFlow Environment Variables
# Copy this file to .env and fill in values
# ──────────────────────────────────────

# ── Supabase ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ── Database (direct connection for API/worker) ──
DATABASE_URL=postgresql://postgres:your-password@localhost:5432/fitflow
DATABASE_POOL_URL=postgresql://postgres:your-password@localhost:6543/fitflow

# ── API Server ──
API_HOST=0.0.0.0
API_PORT=3001
API_BASE_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# ── Auth ──
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# ── ExerciseDB (RapidAPI) ──
EXERCISEDB_API_KEY=your-rapidapi-key
EXERCISEDB_API_HOST=exercisedb.p.rapidapi.com
EXERCISEDB_CACHE_TTL_DAYS=30

# ── Expo Push Notifications ──
EXPO_ACCESS_TOKEN=your-expo-access-token

# ── Sentry ──
SENTRY_DSN=https://your-sentry-dsn
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ── PostHog ──
POSTHOG_API_KEY=your-posthog-key
POSTHOG_HOST=https://app.posthog.com

# ── Web App ──
NEXT_PUBLIC_API_URL=http://localhost:3001/v1
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Docker / Self-Hosted ──
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-db-password
POSTGRES_DB=fitflow
REDIS_URL=redis://localhost:6379
