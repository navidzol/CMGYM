# ──────────────────────────────────────
# CMGYM Environment Variables
# Copy this file to .env and fill in values
# ──────────────────────────────────────

# ── App Identity ──
# Change this to rebrand the app everywhere (UI, emails, notifications)
APP_NAME=CMGYM
NEXT_PUBLIC_APP_NAME=CMGYM

# ── Supabase ──
# 1. Go to https://supabase.com → Create a free project
# 2. Go to Project Settings → API
# 3. Copy "Project URL" → SUPABASE_URL
# 4. Copy "anon public" key → SUPABASE_ANON_KEY
# 5. Copy "service_role" key → SUPABASE_SERVICE_ROLE_KEY (keep secret!)
# 6. Go to Project Settings → API → JWT Settings → copy JWT Secret
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ── Database (direct connection for API/worker) ──
# If self-hosting with Docker Compose, these are auto-configured.
# If using Supabase hosted DB:
#   Go to Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:your-password@localhost:5432/cmgym
DATABASE_POOL_URL=postgresql://postgres:your-password@localhost:6543/cmgym

# ── API Server ──
API_HOST=0.0.0.0
API_PORT=3001
API_BASE_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# ── Auth ──
# Generate a random 32+ char secret: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRES_IN=7d

# ── ExerciseDB (free, no key required) ──
# Uses the free OSS API from AscendAPI. No sign-up needed.
# Docs: https://docs.ascendapi.com/products/edb-v1/overview
# Note: has rate limits — all responses are cached server-side in our DB.
EXERCISEDB_BASE_URL=https://oss.exercisedb.dev/api/v1
EXERCISEDB_CACHE_TTL_DAYS=30

# ── Expo Push Notifications ──
# 1. Go to https://expo.dev → Sign in / Create account
# 2. Go to Account Settings → Access Tokens → Create token
# Only needed if you want push notifications (workout reminders, PR alerts)
EXPO_ACCESS_TOKEN=

# ── Sentry (error monitoring, optional) ──
# 1. Go to https://sentry.io → Create free account
# 2. Create a new project (platform: Node.js for API, React Native for mobile)
# 3. Copy the DSN from Project Settings → Client Keys
# 4. Auth token: Settings → Auth Tokens → Create (for source maps upload)
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ── PostHog (analytics, optional) ──
# 1. Go to https://posthog.com → Create free account (1M events/month free)
# 2. Go to Project Settings → copy your Project API Key
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# ── Web App ──
NEXT_PUBLIC_API_URL=http://localhost:3001/v1
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Docker / Self-Hosted ──
# These are used by docker-compose.yml to create the Postgres container.
# Change POSTGRES_PASSWORD to something strong!
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-db-password
POSTGRES_DB=cmgym
REDIS_URL=redis://localhost:6379
